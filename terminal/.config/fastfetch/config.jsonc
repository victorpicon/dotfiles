        { 
		"type": "cpu", 
		"key": "  ¾░╗á  CPU", 
		"keyColor": "blue", 
		"format": "{1}" 
	},
        { 
		"type": "gpu", 
		"key": "  ¾░ó«  GPU", 
		"keyColor": "blue", 
		"format": "{1} {2}" 
	},
        { 
		"type": "memory", 
		"key": "  ¾░ìø  Memory", 
		"keyColor": "blue", 
		"format": "{1} / {2} {3}" 
	},
        // { "type": "disk", "key": "  ¾░ïè  Disk", "keyColor": "magenta", "format": "{1} / {2} {3}" },
	{ 
		"type": "command", 
		"key": "  ¾░ïè  Storage", 
		"keyColor": "magenta",
		"text": "df -B1 --output=source,size,used | awk '$1 ~ /^\\/dev\\// {s+=$2; u+=$3} END {printf \"%.1fG / %.1fG (%.0f%%)\", u/1e9, s/1e9, (u/s)*100}'",
		"format": "{1}"
	},
	{ 
		"type": "custom", 
		"key": "  ¯╣ÿ  IEMs", 
		"keyColor": "magenta",
		"format": "Truthear Zero: Red"
	},
